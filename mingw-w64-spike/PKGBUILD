# Contributor: Oleg A. Khlybov <fougas@mail.ru>

_realname=spike

pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=1.0
pkgrel=1
arch=('any')
pkgdesc="Banded linear system solver (mingw-w64)"
depends=("${MINGW_PACKAGE_PREFIX}-gcc-libs"
         "${MINGW_PACKAGE_PREFIX}-gcc-libgfortran"
         "${MINGW_PACKAGE_PREFIX}-openblas")
makedepends=("${MINGW_PACKAGE_PREFIX}-gcc"
             "${MINGW_PACKAGE_PREFIX}-gcc-fortran")
optdepends=("${MINGW_PACKAGE_PREFIX}-tcl: build & run test suite")
options=('strip' 'staticlibs')
license=('3-Clause BSD')
url="http://www.spike-solver.org/"
source=("http://www.ecs.umass.edu/~polizzi/spike/spike-${pkgver}.tar.gz"
        "0001-make.inc.patch"
        "0002-disable-scgbmm-dzgbmm.patch"
        "all.tcl"
        "tclbuildtest.tcl"
        "spike.test")
sha256sums=('e5d665fdb7043043f0799ae3dbe3b37e5b200d1ab7a6f7b2a4e463fd89507fa4'
            '394a9e6de6147c33881b7935a2a70f4803eea537faf7b8c74b7cb8236c7f1f87'
            'ec5072630e1c0309fe383669e9187790cd135a393c67bc4bc35cf60b0ba396ff'
            '15c7af25b91406d5fe5f26cfe00963b6cfde1c3dd466eb25f1b6fae299934966'
            '0b58c5bb34403a69bc4c4ab1ab551876695bff1f2be66ecaa9b5528a74e8f8f6')

prepare() {
  cd "${srcdir}/${_realname}-${pkgver}"
  for p in ${srcdir}/*.patch; do
    patch -p1 -i $p
  done
}

build() {
  cd "${srcdir}/${_realname}-${pkgver}/src"
  make ARCH=${CARCH} all -j
  cd ../lib/${CARCH}
  gfortran -shared -fopenmp -Wl,--enable-auto-import -Wl,--export-all-symbols -o lib${_realname}.dll -Wl,--out-implib,lib${_realname}.dll.a -Wl,--whole-archive lib${_realname}.a -Wl,--no-whole-archive $(pkg-config openblas --libs)
}

package() {
  cd "$srcdir/${_realname}-${pkgver}"
  mkdir -p ${pkgdir}${MINGW_PREFIX}/{bin,lib,include} ${pkgdir}${MINGW_PREFIX}/lib/pkgconfig ${pkgdir}${MINGW_PREFIX}/share/test/${_realname}
  (
    cd lib/${CARCH}
    install -m644 *.a "${pkgdir}${MINGW_PREFIX}/lib"
    install -m644 *.dll "${pkgdir}${MINGW_PREFIX}/bin"
  )
  (
    cd include
    install -m644 *.h "${pkgdir}${MINGW_PREFIX}/include"
  )
  cp ${srcdir}/{all.tcl,tclbuildtest.tcl,spike.test} examples/C/?spike_gbsv.c examples/Fortran/driver_dspike_gbsv.f90 ${pkgdir}${MINGW_PREFIX}/share/test/spike
  echo "
    prefix=${MINGW_PREFIX}
    libdir=\${prefix}/lib
    includedir=\${prefix}/include
    Name: ${_realname}
    URL: ${url}
    Version: ${pkgver}
    Description: Banded linear system solver
    Requires.private: openblas
    Cflags: -I\${includedir}
    Libs.private: -fopenmp -l${_realname} -lgfortran -lquadmath
    Libs: -L\${libdir} -l${_realname}
  " | sed '/^\s*$/d;s/^\s*//' > "${pkgdir}${MINGW_PREFIX}/lib/pkgconfig/${_realname}.pc"
}
